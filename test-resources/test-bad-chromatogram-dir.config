//
// Negative test: chromatogram_library_spectra_dir set to the '//' placeholder that the
// config-builder can emit for an empty optional field. '//' is not a Panorama URL, so it
// is treated as a local directory and resolves to the filesystem root '/'. The run must
// fail fast with a clear, parameter-attributed message from resolve_user_path()/list_user_dir()
// instead of an opaque NIO error (the original symptom was a bare `ERROR ~ /root`).
//
// Expected: non-zero exit with a message naming `chromatogram_library_spectra_dir` and the
// filesystem-root / placeholder explanation. See .github/workflows/push-stub-run.yml.
//

params {
    search_engine = 'diann'

    // valid wide-window input so the run reaches the chromatogram-library branch
    quant_spectra_dir = 'test-resources/wide-window'
    quant_spectra_glob = '*.raw'

    // the placeholder value under test
    chromatogram_library_spectra_dir = '//'

    fasta = 'test-resources/test.fasta'
    replicate_metadata = null
    qc_report.skip = true
}

profiles {
    standard {
        process {
            resourceLimits = [cpus: 2, memory: '4.GB', time: '1.h']
        }

        params.mzml_cache_directory = './mzml_cache'
        params.panorama_cache_directory = './raw_cache'
    }
}
