// CI-only overrides for GitHub-hosted runners (4 CPUs, ~16 GB RAM).
//
// Several modules hardcode `cpus 8` or higher. Stub-runs don't actually
// consume CPU, but the local executor still rejects tasks whose `cpus`
// directive exceeds the host's available CPUs before `resourceLimits`
// gets a chance to cap the request. Pretending the executor has more
// CPUs than the runner does bypasses that check for stub-runs only.
executor {
    cpus   = 32
    memory = '32.GB'
}

process {
    resourceLimits = [cpus: 2, memory: '4.GB', time: '1.h']
}
